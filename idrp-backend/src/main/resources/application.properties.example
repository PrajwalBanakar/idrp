spring.application.name=idrp-backend
spring.datasource.url=jdbc:postgresql://localhost:5432/idrp_db
spring.datasource.username=postgres
spring.datasource.password=change-me

spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=true
spring.jpa.properties.hibernate.format_sql=true

server.port=8080

app.jwt.secret=change-me-generate-a-random-base64-secret
app.jwt.expiration=86400000

# Auto-creates one SUPER_ADMIN on first startup if the admins table is empty.
# Leave blank after the first admin exists - has no effect once any admin row exists.
app.admin.bootstrap-email=
app.admin.bootstrap-password=

# Set to true to import the static frontend content (seed/*.json) into the database
# on startup. Safe to re-run - matches existing records by natural key and updates
# them in place instead of duplicating.
app.seed-static-data=false

spring.servlet.multipart.max-file-size=10MB
spring.servlet.multipart.max-request-size=10MB

app.upload.dir=uploads
app.upload.base-url=http://localhost:8080/uploads

app.cors.allowed-origins=http://localhost:5173

# Only the health endpoint is exposed - never widen this without also locking it
# down behind admin auth, since other actuator endpoints can leak internal details.
management.endpoints.web.exposure.include=health
