# Base URL of the idrp-backend API (no trailing slash).
# Used for public GET endpoints, form submissions, and all admin/JWT-protected calls.
VITE_API_BASE_URL=http://localhost:8080

# Access key for Web3Forms (https://web3forms.com), used as a fallback submission
# endpoint for some public forms. Leave blank to disable Web3Forms submissions.
VITE_WEB3FORMS_ACCESS_KEY=
