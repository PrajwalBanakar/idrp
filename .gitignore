# This root folder is not itself a git repository (idrp-frontend and idrp-backend each
# have their own .git). This file is a safety net in case a tool or editor treats the
# root as a repo.

# --- Vue / Vite (frontend) ---
node_modules
dist
dist-ssr
coverage
*.local
*.tsbuildinfo
.eslintcache

# --- Spring Boot / Maven (backend) ---
target/
!**/src/main/**/target/
!**/src/test/**/target/
.mvn/wrapper/maven-wrapper.jar
uploads/

# --- Editors / OS ---
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# --- Env ---
.env
